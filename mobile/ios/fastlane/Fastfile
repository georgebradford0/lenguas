default_platform(:ios)

platform :ios do
  desc "Build release IPA and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "7XMT6777TY",
      issuer_id: "6d3b36f3-dda1-4403-88a4-1e09b6cd9e89",
      key_filepath: File.expand_path("../fastlane/AuthKey_7XMT6777TY.p8", __dir__)
    )

    build_app(
      workspace: "Lenguas.xcworkspace",
      scheme: "Lenguas",
      configuration: "Release",
      export_method: "app-store"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Bump build number to one above the highest build across all versions"
  lane :bump_build_number do
    app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
    )

    app = Spaceship::ConnectAPI::App.find("com.lenguas")
    builds = Spaceship::ConnectAPI::Build.all(app_id: app.id)
    max_build_number = builds.map { |b| b.version.to_i }.max || 0

    increment_build_number(
      build_number: max_build_number + 1,
      xcodeproj: "Lenguas.xcodeproj",
    )
  end

  desc "Upload IPA to TestFlight (CI use, reads IPA_PATH env var)"
  lane :upload_tf do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: ENV["IPA_PATH"],
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload existing Lenguas.ipa to TestFlight (no rebuild)"
  lane :upload do
    api_key = app_store_connect_api_key(
      key_id: "7XMT6777TY",
      issuer_id: "6d3b36f3-dda1-4403-88a4-1e09b6cd9e89",
      key_filepath: File.expand_path("../fastlane/AuthKey_7XMT6777TY.p8", __dir__)
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "Lenguas.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
